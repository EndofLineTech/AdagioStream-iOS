{"id":"mobilemusic-nsd","title":"Stop playback when CarPlay disconnects","description":"When the user unplugs from CarPlay, audio playback continues on the iPhone. The app should detect the CarPlay session ending and automatically stop playback, since the user likely intended to stop listening when they disconnected.","status":"closed","priority":2,"issue_type":"feature","created_at":"2026-02-24T12:56:33.465084-06:00","created_by":"lecaptainc","updated_at":"2026-02-24T13:13:01.168872-06:00","closed_at":"2026-02-24T13:13:01.168872-06:00","close_reason":"Closed","labels":["carplay","enhancement"]}
{"id":"mobilemusic-o3p","title":"Add favorite channels from CarPlay now playing interface","description":"Users should be able to favorite/unfavorite channels directly from the CarPlay playback interface without needing to go back to the channel list. Add a favorite button to the CarPlay now playing screen.","status":"closed","priority":2,"issue_type":"feature","created_at":"2026-02-24T12:56:23.055843-06:00","created_by":"lecaptainc","updated_at":"2026-02-24T13:18:45.522324-06:00","closed_at":"2026-02-24T13:18:45.522324-06:00","close_reason":"Closed","labels":["carplay","enhancement"]}
