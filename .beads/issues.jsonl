{"id":"mobilemusic-blx.1","title":"Add drag and drop support","description":"Drag channels to favorites list. Add Transferable conformance to Channel model. Support dropping M3U URLs to add providers. Use .draggable() and .dropDestination() modifiers.","status":"open","priority":3,"issue_type":"feature","created_at":"2026-02-25T10:37:04.386904-06:00","created_by":"lecaptainc","updated_at":"2026-02-25T10:37:04.386904-06:00","dependencies":[{"issue_id":"mobilemusic-blx.1","depends_on_id":"mobilemusic-blx","type":"parent-child","created_at":"2026-02-25T10:37:04.387502-06:00","created_by":"lecaptainc"}]}
